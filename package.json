{
  "name": "private-websocket",
  "version": "1.0.0",
  "private": true,
  "description": "KoinBX private Azure Web PubSub Socket.IO server – relays Pi42 private FAWSS events to clients via Azure",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "dev": "ts-node src/main.ts",
    "start:dev": "ts-node src/main.ts"
  },
  "dependencies": {
    "@azure/web-pubsub-socket.io": "^1.1.2",
    "@nestjs/common": "^11.1.24",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.24",
    "@nestjs/platform-express": "^11.1.24",
    "@nestjs/platform-socket.io": "^11.1.24",
    "@nestjs/websockets": "^11.1.24",
    "@types/jsonwebtoken": "^9.0.10",
    "dotenv": "^16.4.5",
    "jsonwebtoken": "^9.0.3",
    "mssql": "^12.5.5",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "4.7.5",
    "socket.io-client": "4.7.5"
  },
  "devDependencies": {
    "@types/mssql": "^12.3.0",
    "@types/node": "^22.10.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
